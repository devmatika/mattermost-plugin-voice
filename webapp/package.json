{
  "private": true,
  "scripts": {
    "build": "webpack --mode=production",
    "debug": "webpack --mode=none",
    "lint": "eslint --ignore-pattern node_modules --ignore-pattern dist --ext .js --ext .jsx --quiet",
    "fix": "eslint --ignore-pattern node_modules --ignore-pattern dist --ext .js --ext .jsx --quiet --fix",
    "test": "jest --forceExit --detectOpenHandles --verbose"
  },
  "devDependencies": {
    "@babel/core": "7.25.2",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "7.20.7",
    "@babel/plugin-syntax-dynamic-import": "7.8.3",
    "@babel/preset-env": "7.25.4",
    "@babel/preset-react": "7.24.7",
    "@babel/preset-typescript": "7.24.7",
    "@emotion/babel-preset-css-prop": "11.2.0",
    "@types/jest": "27.4.0",
    "@types/react": "18.2.64",
    "@types/react-dom": "18.2.25",
    "@types/react-redux": "7.1.22",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.0.2",
    "babel-eslint": "10.1.0",
    "babel-loader": "9.1.2",
    "babel-plugin-formatjs": "10.3.7",
    "babel-plugin-typescript-to-proptypes": "2.0.0",
    "css-loader": "6.5.1",
    "eslint": "8.57.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-react": "7.34.1",
    "eslint-plugin-react-hooks": "4.6.0",
    "file-loader": "6.2.0",
    "jest": "27.4.7",
    "jest-canvas-mock": "2.3.1",
    "jest-junit": "13.0.0",
    "sass": "1.52.3",
    "sass-loader": "13.0.0",
    "style-loader": "3.3.1",
    "webpack": "5.95.0",
    "webpack-cli": "5.1.4"
  },
  "dependencies": {
    "@emotion/react": "11.9.0",
    "@mattermost/types": "11.7.0",
    "core-js": "3.26.0",
    "mattermost-redux": "11.7.0",
    "react": "18.2.0",
    "react-redux": "9.2.0",
    "redux": "5.0.1",
    "typescript": "4.9.5"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "clearMocks": true,
    "moduleNameMapper": {
      "^.+\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "identity-obj-proxy",
      "^.+\\.(css|less|scss)$": "identity-obj-proxy",
      "^.*i18n.*\\.(json)$": "<rootDir>/tests/i18n_mock.json"
    },
    "moduleDirectories": [
      "src",
      "node_modules"
    ],
    "setupFiles": [
      "jest-canvas-mock"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testURL": "http://localhost:8065"
  }
}
